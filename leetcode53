class Solution:
    def maxSubArray(self, nums: List[int]) -> int:
        currentSum = 0
        maxNum = nums[0]
        
        for i in range(len(nums)):
            
            if currentSum < 0:
                currentSum = 0
            
            currentSum = currentSum + nums[i]
            maxNum = max(maxNum, currentSum)
        
        return maxNum
