class Solution:
    def maxProduct(self, nums: List[int]) -> int:
        if not nums:
          return 0
        min_val = nums[0]
        max_val = nums[0]
        result = max_val
        for i in range(1, len(nums)):
            cur = nums[i]
            temp = max(cur, max_val * cur, min_val * cur)
            min_val = min(cur, min_val * cur, max_val *cur)
            max_val = temp
            result = max(result, max_val)

        return result
